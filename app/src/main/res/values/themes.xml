<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.KhoiHealth" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/khoi_teal_700</item>
        <item name="colorPrimaryVariant">@color/khoi_teal_500</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="android:windowBackground">@color/background_light</item>
        <item name="android:statusBarColor">@color/background_light</item>
        <item name="android:navigationBarColor">@color/surface_white</item>
    </style>

    <style name="Theme.KhoiHealth.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/khoi_teal_700</item>
        <item name="windowSplashScreenAnimatedIcon">@android:drawable/ic_media_play</item>
        <item name="postSplashScreenTheme">@style/Theme.KhoiHealth</item>
    </style>
</resources>
